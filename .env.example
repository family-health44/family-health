# Family Health — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must NEVER be committed.
# For production, set these as EAS Secrets — never in eas.json or app.config.ts.

# Supabase — from your Supabase project dashboard → Settings → API
# The anon key is safe for client-side use provided RLS is correctly configured.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# EAS — from running `eas init` (Step 9)
EAS_PROJECT_ID=your-eas-project-id
